# Qwen Cloud (DashScope International) API key. Server-side only; never exposed to the client.
QWEN_CLOUD_API_KEY=

# Optional overrides
# ENGRAM_CHAT_MODEL=qwen3.7-plus
# ENGRAM_DB=./engram.db
# ENGRAM_RECALL_BUDGET=800

# Optional distributed rate limiting (falls back to in-memory without these).
# Vercel KV integration names:
# KV_REST_API_URL=
# KV_REST_API_TOKEN=
# Raw Upstash names:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
